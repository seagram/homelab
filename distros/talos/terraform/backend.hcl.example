bucket = "homelab-terraform-state-bucket"
key    = "homelab/terraform.tfstate"
region = "us-east-1"

# AWS credentials are read from environment variables:
#   AWS_ACCESS_KEY_ID
#   AWS_SECRET_ACCESS_KEY
#
# minimum IAM permissions on the bucket:
#   s3:ListBucket
#   s3:GetObject
#   s3:PutObject
#   s3:DeleteObject
