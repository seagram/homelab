#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
  identity:
    hostname: ubuntu-template
    username: packer
    # throwaway password
    # this is file is served statically so packer can't template it
    # has to be hardcoded
    # cloud-init will override it on clone so it's safe to hardcode
    # to generate, run: openssl passwd -6 "packer"
    password: "$6$rounds=4096$randomsalt$KjJq3aKm0fF9dYj.HsOmKrMhCnKxkRwRkEFYfCMmZYwFG0fLbVnYI8FDK7GIE.4RYHjKBnZkUMB5nYIHl/Gs/"
  ssh:
    install-server: true
    allow-pw: true
  storage:
    layout:
      name: lvm
  packages:
    - qemu-guest-agent
  late-commands:
  # ran at end of autoinstall & before the reboot
  # use curtin in-target -- so the command is ran inside the installed system and not the live installer environment
    - "curtin in-target -- systemctl enable qemu-guest-agent"
